# pyenv
#   For a library or binary, you shouldn't ignore these files, but for a specific
#   project, it can be useful to ignore them.
# .python-version

# pipenv
#   According to pypa/pipenv#1173, it is recommended not to commit bin/
#   in the case of using a virtualenv.
# bin/

# poetry
#   Similar to pipenv, it's generally recommended to commit pyproject.toml and poetry.lock
# poetry.lock
# pyproject.toml

# pdm
#   Similar to poetry, it's generally recommended to commit pyproject.toml and pdm.lock
# pdm.lock
# .pdm.toml

# PEP 582; used by e.g. github.com/frenzymadness/venvpdm
__pypackages__/

